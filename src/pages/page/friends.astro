---
import Layout from "../../layouts/BlogPage.astro";
import MarkdownBody from "../../components/MarkdownBody.astro";
import * as markdownData from "./_friends.md";
---

<Layout
    title="鱼塘 - LineXic书屋"
    description="LineXic书屋的友链订阅页面,可以随时查看朋友更新的文章"
>
    <MarkdownBody class="mt-6">
        <markdownData.Content />
<div id="friend-circle-lite-root"></div>
<script>
    if (typeof UserConfig === 'undefined') {
        var UserConfig = {
            // 填写你的fc Lite地
            private_api_url: 'https://fc.linexic.top/',
            // 点击加载更多时，一次最多加载几篇文章，默认20
            page_turning_number: 24,
            // 头像加载失败时，默认头像地址
            error_img: 'https://pic.imgdb.cn/item/6695daa4d9c307b7e953ee3d.jpg',
        }
    }
</script>
<link rel="stylesheet" href="https://fastly.jsdelivr.net/gh/willow-god/Friend-Circle-Lite/main/fclite.min.css">
<script src="https://fastly.jsdelivr.net/gh/willow-god/Friend-Circle-Lite/main/fclite.min.js"></script>


    </MarkdownBody>
</Layout>