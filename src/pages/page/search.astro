---
import Search from "astro-pagefind/components/Search";
import Layout from "../../layouts/BlogPage.astro";
import MarkdownBody from "../../components/MarkdownBody.astro";
import * as markdownData from "./_search.md";

---

<Layout
    title="搜索 - LineXic书屋"
    description="LineXic书屋的搜索功能,可以在这里搜索本站所有的文章内容"
>
    <MarkdownBody class="mt-6">
        <markdownData.Content />
        <Search
  id="search" 
  className="pagefind-ui" 
  uiOptions={{ 
    showImages: false,
    placeholderText: "",
    showEmptyResults: true,
    showSubResults: true,
    resetStyles: true,
    translations: {
      placeholder: "",
      clear_search: "清除",
      load_more: "加载更多结果",
      search_label: "搜索网站",
      filters_label: "筛选",
      zero_results: "未找到与 [SEARCH_TERM] 相关的结果",
      many_results: "找到 [COUNT] 个与 [SEARCH_TERM] 相关的结果",
      one_result: "找到 1 个与 [SEARCH_TERM] 相关的结果",
      searching: "搜索 [SEARCH_TERM] 中..."
    }
  }}
/>

<style is:global>
    /* 根 CSS 变量 - Pagefind 搜索 UI 的全局默认样式 */
    :root {
        --pagefind-ui-scale: 0.8; /* 搜索 UI 元素的整体缩放比例 */
        --pagefind-ui-primary: var(--menu-surface); /* UI 元素的主色调 */
        --pagefind-ui-text: hsl(240, 2%, 36%); /* 基础文本颜色 */
        --pagefind-ui-message-text: var(--color-accent-300); /* 状态消息文本颜色 */
        --pagefind-ui-result-title-text: var(--brand); /* 搜索结果标题颜色 */
        --pagefind-ui-result-text: #a9a9a9; /* 搜索结果描述文本颜色 */
        --pagefind-ui-background: var(--surface1); /* UI 容器背景色 */
        --pagefind-input-background: var(--brand); /* 搜索输入框背景色 */
        --pagefind-ui-border: #413f3f; /* UI 元素边框颜色 */
        --pagefind-ui-border-width: 2px; /* 边框宽度 */
        --pagefind-ui-border-radius: 8px; /* 圆角边框半径 */
        --pagefind-ui-image-border-radius: 8px; /* 结果图片圆角半径 */
        --pagefind-ui-image-box-ratio: 3 / 2; /* 结果图片宽高比 */
        --pagefind-ui-font: sans-serif; /* UI 元素字体族 */
        --pagefind-button-background: var(--pagefind-input-background); /* 按钮背景色 */
        --pagefind-button-color: var(--pagefind-ui-message-text); /* 按钮文本颜色 */
    }

    /* 浅色主题覆盖 - 仅适用于浅色模式的变量 */
    [data-theme="light"] {
         --pagefind-ui-primary: var(--menu-surface);
         --pagefind-ui-text: hsl(252, 26%, 96%);
         --pagefind-ui-message-text: var(--color-accent-300);
         --pagefind-ui-result-title-text: var(--brand);
         --pagefind-ui-result-text: #a9a9a9;
         --pagefind-ui-background: var(--surface1);
         --pagefind-input-background: var(--brand);
         --pagefind-ui-border: #413f3f;
         --pagefind-button-color: var(--pagefind-ui-text); /* 浅色模式下的按钮文本颜色覆盖 */
     }

    /* 深色主题覆盖 - 仅适用于深色模式的变量 */
    [data-theme="dark"] {
     --pagefind-ui-primary: var(--menu-surface);
     --pagefind-ui-text: hsl(252, 26%, 96%);
     --pagefind-ui-message-text: var(--pagefind-ui-text); /* 深色模式下使用基础文本颜色作为消息文本颜色 */
     --pagefind-ui-result-title-text: var(--accent1); /* 深色模式下使用强调色作为结果标题颜色 */
     --pagefind-ui-result-text: #a9a9a9;
     --pagefind-ui-background: var(--surface1); /* 深色模式自定义背景色 */
     --pagefind-input-background: var(--brand);
     --pagefind-ui-border: var(--brand); /* 深色模式下使用品牌色作为边框颜色 */
     }

    /* 搜索输入框样式 */
    #search .pagefind-ui__search-input, #search .pagefind-ui__search-clear {
      background-color: var(--pagefind-input-background); /* 应用输入框背景色变量 */
      color: var(--pagefind-ui-text); /* 应用文本颜色变量 */
     }

    /* 搜索结果标题样式 */
    #search .pagefind-ui__result-title, #search .pagefind-ui__result-link {
     display: inline-block; /* 将标题设置为内联块级元素以控制布局 */
     font-weight: 700; /* 标题文本加粗 */
     font-size: calc(1.8rem * var(--pagefind-ui-scale)); /* 应用缩放后的字体大小 */
     color: var(--pagefind-ui-result-title-text); /* 应用标题颜色变量 */
    }

    /* 搜索结果摘要文本样式 */
    #search .pagefind-ui__result-excerpt {
     color: var(--pagefind-ui-result-text); /* 应用摘要文本颜色变量 */
     font-weight: 400; /* 摘要文本常规字重 */
     font-size: calc(1rem * var(--pagefind-ui-scale)); /* 应用缩放后的字体大小 */
    }

    /* 状态消息样式（如 "未找到结果"） */
    #search .pagefind-ui__message {
     color: var(--pagefind-ui-message-text); /* 应用消息颜色变量 */
     margin: calc(0.5rem * var(--pagefind-ui-scale)) 0 calc(1.5rem * var(--pagefind-ui-scale)) calc(0.5rem * var(--pagefind-ui-scale)); /* 应用缩放后的外边距 */
    }

    /* 按钮样式（如分页按钮、筛选按钮） */
    #search .pagefind-ui__button {
     color: var(--pagefind-button-color); /* 应用按钮文本颜色变量 */
     background: var(--pagefind-button-background); /* 应用按钮背景色变量 */
    }

    /* 隐藏结果缩略图（禁用搜索结果中的图片预览） */
    #search .pagefind-ui__result-thumb {
     display: none;
    }
</style>
    </MarkdownBody>
</Layout>